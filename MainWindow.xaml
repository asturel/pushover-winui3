<Window
    x:Class="PushoverDesktopClient.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PushoverDesktopClient"
    Title="Pushover Pro Client - Pure Native Windows 11">

    <Grid Background="#1C1C1C">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" Background="#232323" HorizontalAlignment="Stretch" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="SidebarPanel" Spacing="5" Margin="10">
                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" Padding="10" Click="AllMessagesButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE71D;" FontSize="16" />
                            <TextBlock Text="All Messages" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="1" Spacing="8" Margin="10">
                <Button x:Name="ConnectBtn" Content="Connect" HorizontalAlignment="Stretch" Click="StartClient_Click" />
                <Button x:Name="SimulateBtn" Content="Simulate Notification" HorizontalAlignment="Stretch" Click="SimulateNotification_Click" Visibility="Collapsed" />
                <Button x:Name="SettingsBtn" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" Padding="10" Click="SettingsButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE713;" FontSize="16" />
                        <TextBlock Text="Settings" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="3*" />
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="16,10,16,10">
                <TextBox x:Name="SearchBox" PlaceholderText="Search messages (title, content, app)..." Width="250" Height="35" VerticalAlignment="Center" HorizontalAlignment="Left" TextChanged="SearchBox_TextChanged" />
            </Grid>

            <Grid Grid.Row="1" Margin="16,0,16,16">
                <ListView x:Name="MessagesListView" ItemsSource="{x:Bind DisplayedMessages}" SelectionMode="None" Background="Transparent" ContainerContentChanging="MessagesListView_ContainerContentChanging">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel ItemsUpdatingScrollMode="KeepItemsInView" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:PushoverMessageEventArgs">
                            <Border x:Name="CardBorder" Padding="12" CornerRadius="8" Margin="0,0,0,8" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" Width="32" Height="32" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,2,0,0">
                                        <Ellipse Fill="#373737" Width="32" Height="32" />
                                        <Image x:Name="AppIconImage" Width="32" Height="32" Stretch="UniformToFill" />
                                        <TextBlock x:Name="FallbackTextBlock" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="LightGray" FontSize="13" FontWeight="Bold" />
                                    </Grid>

                                    <StackPanel Grid.Column="1" Spacing="4" Margin="4,0,8,0">
                                        <TextBlock Text="{Binding Converter={StaticResource TitleFallbackConverter}}" FontSize="14" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" />
                                        <RichTextBlock x:Name="BodyRichTextBlock" FontSize="13" Opacity="0.85" TextWrapping="Wrap" Foreground="#DCDCDC" />
                                        <HyperlinkButton x:Name="CardHyperlinkButton" FontSize="12" Padding="0,2,0,2" HorizontalAlignment="Left" />
                                    </StackPanel>

                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock x:Name="TimeTextBlock" FontSize="11" Opacity="0.5" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,2,4,0" />
                                        <Button x:Name="DeleteButton" Grid.Row="1" Background="Transparent" BorderBrush="Transparent" Foreground="DimGray" Padding="6" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,0,-4">
                                            <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Grid Grid.Row="2" Margin="16,0,16,16" Background="#0F0F0F">
                <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4">
                    <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="LogsContainerPanel" Spacing="2" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>